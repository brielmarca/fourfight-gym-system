# ============================================================
# Four Fight Gym System — Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# API base URL (relative path for dev proxy, full URL for production)
# Dev:  /api  (proxied to localhost:8080 by Vite)
# Prod: https://your-backend.onrender.com/api
VITE_API_URL=https://fourfight-gym-system.onrender.com/api

# Stripe publishable key (safe to expose in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Public checkout gate: set to true only when Stripe live flow is ready.
# Defaults to disabled (false) when missing.
VITE_STRIPE_CHECKOUT_ENABLED=false
