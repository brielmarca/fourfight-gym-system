# ============================================================
# Four Fight Gym System — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# --- Spring Profile ---
# Use "prod" for production, "dev" for local PostgreSQL, "default" for H2
SPRING_PROFILES_ACTIVE=prod

# --- Database (Supabase PostgreSQL) ---
# Get from Supabase project settings → Database → Connection string → URI
DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=your_supabase_db_password

# --- JWT RS256 Keys ---
# Generate with:
#   openssl genrsa -out private_key.pem 2048
#   openssl rsa -in private_key.pem -pubout -out public_key.pem
# Then convert to single-line (replace newlines with \n):
#   awk -v ORS='\\n' '1' private_key.pem
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...your key...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...your key...\n-----END PUBLIC KEY-----
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- CORS ---
# Comma-separated list of allowed frontend origins (HTTPS only in production)
CORS_ALLOWED_ORIGINS=https://your-domain.com

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_FRONTEND_SUCCESS_URL=https://your-domain.com/membership/success
STRIPE_FRONTEND_CANCEL_URL=https://your-domain.com/plans

# --- App ---
APP_FRONTEND_URL=https://your-domain.com

# --- Server ---
# Render sets PORT automatically; this is the fallback
PORT=8080
