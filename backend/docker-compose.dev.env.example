# Four Fight development Compose environment template.
# Copy to backend/docker-compose.dev.env for local Docker Compose only.
# Do not use production credentials here.

DEV_POSTGRES_PASSWORD=fourfight_dev_password
DEV_BACKEND_PORT=8080
DEV_POSTGRES_PORT=55432
DEV_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
DEV_STRIPE_FRONTEND_SUCCESS_URL=http://localhost:5173/membership/success
DEV_STRIPE_FRONTEND_CANCEL_URL=http://localhost:5173/plans
DEV_APP_FRONTEND_URL=http://localhost:5173

# Required for running the backend with the prod profile against local Postgres.
# Generate disposable local keys; never paste production keys here.
JWT_PRIVATE_KEY=replace_with_single_line_local_private_key
JWT_PUBLIC_KEY=replace_with_single_line_local_public_key
MFA_ENCRYPTION_KEY_BASE64=local_development_32_byte_base64_key

# Optional local/test Stripe placeholders. Do not use live keys.
STRIPE_SECRET_KEY=replace_with_test_secret_key
STRIPE_PUBLISHABLE_KEY=replace_with_test_publishable_key
STRIPE_WEBHOOK_SECRET=replace_with_test_webhook_secret
